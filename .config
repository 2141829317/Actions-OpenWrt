# This is an empty file, please overwrite it after generating the .config file with the source code
# =========================================================
# 1. 目标机型 (小米路由器 mini 专属架构)
# =========================================================
CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt7620=y
CONFIG_TARGET_ramips_mt7620_DEVICE_xiaomi_miwifi-mini=y

# =========================================================
# 2. 基础系统与极简 UI (放弃所有花哨主题)
# =========================================================
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-theme-bootstrap=y

# =========================================================
# 3. 核心需求：校园网专用组件 (认证 + 防检测)
# =========================================================
CONFIG_PACKAGE_luci-app-mentohust=y
CONFIG_PACKAGE_mentohust=y
CONFIG_PACKAGE_luci-app-ua2f=y
CONFIG_PACKAGE_ua2f=y

# UA2F 运行必不可少的底层内核依赖 (防止 Lean 源码默认未开启)
CONFIG_PACKAGE_kmod-nft-core=y
CONFIG_PACKAGE_kmod-nft-nat=y
CONFIG_PACKAGE_kmod-nft-netdev=y
CONFIG_PACKAGE_iptables-mod-ipopt=y

# =========================================================
# 4. 极限“去肥增瘦”区 (彻底斩断 Lean 源码的默认累赘)
# =========================================================

# 斩断 1：彻底抛弃 USB 支持 (小米 mini 只有 16M，留着 USB 驱动纯属浪费空间)
# CONFIG_PACKAGE_kmod-usb-core is not set
# CONFIG_PACKAGE_kmod-usb-ohci is not set
# CONFIG_PACKAGE_kmod-usb2 is not set
# CONFIG_PACKAGE_kmod-usb-ledtrig-usbport is not set

# 斩断 2：精准击杀 Lean 源码默认勾选的重型网络插件
# CONFIG_PACKAGE_luci-app-ddns is not set
# CONFIG_PACKAGE_luci-app-upnp is not set
# CONFIG_PACKAGE_luci-app-vlmcsd is not set
# CONFIG_PACKAGE_luci-app-vsftpd is not set
# CONFIG_PACKAGE_luci-app-ssr-plus is not set
# CONFIG_PACKAGE_luci-app-unblockmusic is not set
# CONFIG_PACKAGE_luci-app-uugamebooster is not set
# CONFIG_PACKAGE_luci-app-arpbind is not set
# CONFIG_PACKAGE_luci-app-autoreboot is not set
# CONFIG_PACKAGE_luci-app-filetransfer is not set
# CONFIG_PACKAGE_luci-app-turboacc is not set

# 斩断 3：击杀默认附带的臃肿主题
# CONFIG_PACKAGE_luci-theme-argon is not set
# CONFIG_PACKAGE_luci-theme-design is not set
